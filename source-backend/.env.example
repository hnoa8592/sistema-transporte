# Copiar a .env y ajustar los valores

# Base de datos
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT — generar un secreto seguro en base64 (mínimo 256 bits)
# Ejemplo: openssl rand -base64 64
JWT_SECRET=

# Opcionales (los valores entre paréntesis son los defaults)
SERVER_PORT=8080
JWT_ACCESS_EXPIRATION=900000       # 15 minutos en ms
JWT_REFRESH_EXPIRATION=604800000   # 7 días en ms
RESERVATION_EXPIRY_MINUTES=30

# Perfil Spring (prod | dev)
SPRING_PROFILES_ACTIVE=prod
